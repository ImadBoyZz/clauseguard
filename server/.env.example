# ClauseGuard backend — kopieer dit bestand naar `.env` en vul je OpenRouter-key in.
# Maak een key aan op https://openrouter.ai/keys (één key werkt voor Gemini én Claude).
OPENROUTER_API_KEY=

# Model via OpenRouter. Default = Claude Haiku 4.5 (sterke NL/EN-proeflezer).
# Goedkoper/sneller alternatief: google/gemini-2.5-flash
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

PORT=3001
